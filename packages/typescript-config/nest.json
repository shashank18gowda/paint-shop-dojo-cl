{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "incremental": true,
    "resolvePackageJsonExports": true,
    "allowSyntheticDefaultImports": true,
    "strictPropertyInitialization": false
  }
}

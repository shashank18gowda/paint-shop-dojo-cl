# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5433/ps_dojo

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRY=8h

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
BACKEND_URL=http://localhost:3001
# Comma-separated browser origins allowed for CORS + WebSocket.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=10

# ── Quiz ──────────────────────────────────────────────────────────────────────
QUIZ_PASS_THRESHOLD_PERCENT=50
QUIZ_DEFAULT_QUESTION_COUNT=10
QUIZ_COOLDOWN_PASS_DAYS=365
QUIZ_COOLDOWN_FAIL_DAYS=30

# ── Game ──────────────────────────────────────────────────────────────────────
GAME_COOLDOWN_PASS_DAYS=365
GAME_COOLDOWN_FAIL_DAYS=30

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOADS_PHOTOS_DIR=./uploads/photos
UPLOAD_MAX_SIZE_BYTES=5242880

# ── Pagination / export ───────────────────────────────────────────────────────
EXPORT_MAX_ROWS=10000
ADMIN_DEFAULT_PAGE_SIZE=20

# ── Certificate / branding ────────────────────────────────────────────────────
COMPANY_NAME=TOYOTA KIRLOSKAR MOTOR
TRAINING_PROGRAM_NAME=Paint Shop Training Program
CERT_NUMBER_PREFIX=TKM-PS

# ── Seed admin (used by `pnpm db:seed` to create the first admin) ──────────────
SEED_ADMIN_EMAIL=admin@tkm.co.in
SEED_ADMIN_PASSWORD=change-me-please
SEED_ADMIN_NAME=Admin

# ── Email / Brevo (leave blank to disable report email dispatch) ──────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Paint Shop Dojo

# Admin-app environment template.
# Copy to .env (or .env.local) and edit as needed.
# Both files are gitignored.


# Backend API base URL — baked into the client bundle at build time.
# Match the backend's PORT (apps/backend/.env).
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Admins log in at /login with email + password (POST /api/auth/admin/login).
# A default seeded admin exists: admin@tkm.co.in / change-me-please
# Override SEED_ADMIN_EMAIL / SEED_ADMIN_PASSWORD / SEED_ADMIN_NAME in
# apps/backend/.env if you want different defaults on next seed run.
